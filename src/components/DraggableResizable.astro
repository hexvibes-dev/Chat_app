---
---
<div id="movable-window" 
     class="fixed bg-white rounded-lg shadow-xl border border-gray-300 overflow-hidden"
     style="width: 320px; height: 240px; min-width: 150px; min-height: 100px; max-width: 90vw; max-height: 90vh;">

  <div class="bg-gray-200 px-3 py-2 flex justify-between items-center border-b border-gray-300 select-none">
    <span class="font-medium text-gray-700">Ventana</span>
    <button id="close-btn" class="text-gray-500 hover:text-gray-700 text-lg leading-none">✕</button>
  </div>

  <div class="p-4 overflow-auto h-full">
    <p class="text-gray-600">Arrastra el asa roja (⋮⋮).</p>
    <p class="text-gray-600">Redimensiona desde bordes o esquinas.</p>
  </div>

  <div class="resize-handle resize-n"></div>
  <div class="resize-handle resize-s"></div>
  <div class="resize-handle resize-e"></div>
  <div class="resize-handle resize-w"></div>
  <div class="resize-handle resize-ne"></div>
  <div class="resize-handle resize-nw"></div>
  <div class="resize-handle resize-se"></div>
  <div class="resize-handle resize-sw"></div>
</div>

<div id="drag-handle" 
     class="fixed bg-red-500 hover:bg-red-600 rounded-full w-10 h-10 flex items-center justify-center shadow-lg cursor-grab active:cursor-grabbing z-50 border-2 border-white"
     style="touch-action: none; user-select: none; left: 0; top: 0;">
  <span class="text-white text-xl font-bold">⋮⋮</span>
</div>

<style>
  .resize-handle {
    position: absolute;
    background: rgba(0, 0, 0, 0.1);
    transition: background 0.1s;
    z-index: 10;
    touch-action: none;
  }
  .resize-handle:hover { background: rgba(0, 0, 0, 0.3); }
  .resize-n, .resize-s { left: 10px; right: 10px; height: 12px; }
  .resize-n { top: 0; cursor: n-resize; }
  .resize-s { bottom: 0; cursor: s-resize; }
  .resize-e, .resize-w { top: 10px; bottom: 10px; width: 12px; }
  .resize-e { right: 0; cursor: e-resize; }
  .resize-w { left: 0; cursor: w-resize; }
  .resize-ne, .resize-nw, .resize-se, .resize-sw { width: 18px; height: 18px; }
  .resize-ne { top: 0; right: 0; cursor: ne-resize; }
  .resize-nw { top: 0; left: 0; cursor: nw-resize; }
  .resize-se { bottom: 0; right: 0; cursor: se-resize; }
  .resize-sw { bottom: 0; left: 0; cursor: sw-resize; }

  #movable-window {
    position: fixed;
    transform-origin: top left;
  }
</style>

<script>
  import interact from 'interactjs';

  document.addEventListener('DOMContentLoaded', () => {
    const windowElement = document.getElementById('movable-window');
    const dragHandle = document.getElementById('drag-handle');
    const closeBtn = document.getElementById('close-btn');

    if (!windowElement || !dragHandle) return;

    let windowX = (window.innerWidth - windowElement.offsetWidth) / 2;
    let windowY = (window.innerHeight - windowElement.offsetHeight) / 2;
    windowElement.style.transform = `translate3d(${windowX}px, ${windowY}px, 0)`;
    windowElement.setAttribute('data-x', windowX);
    windowElement.setAttribute('data-y', windowY);

    function updateHandlePosition() {
      const rect = windowElement.getBoundingClientRect();
      dragHandle.style.left = `${rect.left + rect.width / 2 - dragHandle.offsetWidth / 2}px`;
      dragHandle.style.top = `${rect.top - dragHandle.offsetHeight - 5}px`;
    }
    updateHandlePosition();

    const syncHandle = () => updateHandlePosition();

    interact(dragHandle).draggable({
      allowFrom: dragHandle,
      inertia: false,
      preventDefault: 'always',
      manualStart: false,
      listeners: {
        move(event) {
          let x = windowX + event.dx;
          let y = windowY + event.dy;
          windowElement.style.transform = `translate3d(${x}px, ${y}px, 0)`;
          windowElement.setAttribute('data-x', x);
          windowElement.setAttribute('data-y', y);
          windowX = x;
          windowY = y;
          syncHandle();
        }
      }
    });

    interact(windowElement).resizable({
      edges: { top: true, left: true, bottom: true, right: true },
      inertia: false,
      preventDefault: 'always',
      modifiers: [
        interact.modifiers.restrictSize({
          min: { width: 150, height: 100 },
          max: { width: window.innerWidth * 0.9, height: window.innerHeight * 0.9 }
        })
      ],
      listeners: {
        move(event) {
          let width = event.rect.width;
          let height = event.rect.height;
          windowElement.style.width = `${width}px`;
          windowElement.style.height = `${height}px`;
          
          let newX = windowX + event.deltaRect.left;
          let newY = windowY + event.deltaRect.top;
          windowElement.style.transform = `translate3d(${newX}px, ${newY}px, 0)`;
          windowElement.setAttribute('data-x', newX);
          windowElement.setAttribute('data-y', newY);
          windowX = newX;
          windowY = newY;
          syncHandle();
        }
      }
    });
    if (closeBtn) {
      closeBtn.addEventListener('click', () => {
        windowElement.remove();
        dragHandle.remove();
      });
    }
    window.addEventListener('resize', () => {
      syncHandle();
    });
  });
</script>