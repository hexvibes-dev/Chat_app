<section class="bg-slate-700 min-h-screen w-full flex flex-col items-center justify-center gap-5 relative">
  
  <!-- Botones superiores -->
  <div class="absolute top-4 left-4 flex gap-2">
    <button id="togglePanel" 
            class="bg-cyan-600 text-white px-4 py-2 rounded-lg shadow-md hover:bg-cyan-700 transition">
      Estilos
    </button>
    <button id="resetStyles" 
            class="bg-red-600 text-white px-4 py-2 rounded-lg shadow-md hover:bg-red-700 transition">
      Reset
    </button>
  </div>

  <div class="editor-container flex gap-5 w-[90%] max-w-[900px]">
    
    <!-- Editor de código -->
    <textarea 
      id="cssInput" 
      class="flex-1 bg-slate-800 text-green-400 resize-none p-3 rounded-2xl h-[300px] focus:border focus:border-cyan-600 outline-none font-mono"
      placeholder="Ejemplo: bubble:hover:background:red; text:active:color:blue; @keyframes fade-in {...}">
    </textarea>

    <!-- Panel de opciones oculto -->
    <div id="stylePanel" class="hidden flex flex-col bg-slate-900 text-white rounded-xl p-4 w-72 max-h-[300px] overflow-y-auto">
      <div class="flex gap-2 mb-4 sticky top-0 bg-slate-900 pb-2">
        <button id="bubbleBtn" class="flex-1 bg-blue-600 hover:bg-blue-700 rounded px-2 py-1">Bubble (40)</button>
        <button id="textBtn" class="flex-1 bg-green-600 hover:bg-green-700 rounded px-2 py-1">Text (40)</button>
      </div>
      <div id="optionsList" class="flex flex-col gap-2 text-sm">
        <!-- Aquí se llenan dinámicamente las opciones -->
      </div>
    </div>

    <!-- Vista previa -->
    <div class="preview flex flex-1 items-center justify-center bg-slate-500 rounded-2xl p-5">
      <div id="bubble" 
           class="bubble w-40 h-40 rounded-full bg-blue-500 flex items-center justify-center text-center shadow-inner shadow-black/50 transition-all duration-300 ease-in-out cursor-pointer">
        <p id="bubbleText" class="text-white text-base m-0 cursor-pointer">Texto dentro de la burbuja</p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Animaciones predefinidas */
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fade-out {
    from { opacity: 1; }
    to { opacity: 0; }
  }
  /* Mejora para móvil: active visible */
  #bubble:active, #bubbleText:active {
    transform: scale(0.98);
  }
</style>

<script>
const cssInput = document.getElementById("cssInput");
const bubble = document.getElementById("bubble");
const bubbleText = document.getElementById("bubbleText");

// Botones
const togglePanel = document.getElementById("togglePanel");
const stylePanel = document.getElementById("stylePanel");
const bubbleBtn = document.getElementById("bubbleBtn");
const textBtn = document.getElementById("textBtn");
const resetBtn = document.getElementById("resetStyles");
const optionsList = document.getElementById("optionsList");

// ========== SANITIZACIÓN ==========
function sanitize(prop, val) {
  if (prop.includes("width") || prop.includes("height") || prop.includes("fontSize")) {
    const num = parseInt(val);
    if (!isNaN(num)) {
      if (num < 10) return "10px";
      if (num > 300) return "300px";
    }
  }
  if (prop.includes("translate")) {
    const num = parseInt(val);
    if (!isNaN(num)) {
      if (num < -200) return "-200px";
      if (num > 200) return "200px";
    }
  }
  return val;
}

// ========== APLICAR ESTILOS DESDE TEXTAREA ==========
function applyStylesFromTextarea() {
  try {
    bubble.style.cssText = "";
    bubbleText.style.cssText = "";

    const oldDynamicStyle = document.getElementById("dynamic-pseudo-styles");
    if (oldDynamicStyle) oldDynamicStyle.remove();

    let pseudoCssRules = "";
    const code = cssInput.value;
    const rules = code.split(";");

    rules.forEach(rule => {
      if (rule.trim() !== "") {
        if (rule.trim().startsWith("@keyframes")) {
          const keyframeName = rule.match(/@keyframes\s+(\w+)/)?.[1];
          if (keyframeName) {
            const existingStyle = document.querySelector(`style[data-keyframe="${keyframeName}"]`);
            if (existingStyle) existingStyle.remove();
          }
          const styleTag = document.createElement("style");
          styleTag.setAttribute("data-keyframe", keyframeName || "custom");
          styleTag.innerHTML = rule.trim();
          document.head.appendChild(styleTag);
          return;
        }

        const parts = rule.split(":");
        if (parts.length >= 3) {
          let target = parts[0].trim();
          let propPart = parts[1].trim();
          let val = parts.slice(2).join(":").trim();
          val = sanitize(propPart, val);

          let pseudo = null;
          let realProp = propPart;
          if (propPart.includes(":")) {
            const pseudoParts = propPart.split(":");
            pseudo = pseudoParts[0];
            realProp = pseudoParts[1];
          }

          const element = target === "bubble" ? bubble : bubbleText;
          if (element) {
            if (pseudo) {
              const selector = target === "bubble" 
                ? `#bubble${pseudo}` 
                : `#bubbleText${pseudo}`;
              pseudoCssRules += `${selector} { ${realProp}: ${val}; }\n`;
            } else {
              element.style[realProp] = val;
            }
          }
        }
      }
    });

    if (pseudoCssRules.trim() !== "") {
      const styleTag = document.createElement("style");
      styleTag.id = "dynamic-pseudo-styles";
      styleTag.innerHTML = pseudoCssRules;
      document.head.appendChild(styleTag);
    }
  } catch (e) {
    console.error("Error aplicando estilos:", e);
  }
}

cssInput.addEventListener("input", applyStylesFromTextarea);

// ========== GENERAR 40 ESTILOS PARA BURBUJA (SÓLO 3 CON PSEUDO) ==========
// Lista de estilos normales (sin pseudo) - animaciones, colores, sombras, transforms, etc.
const bubbleNormalStyles = [
  "bubble:animation:bounce 1s infinite",
  "bubble:animation:pulse 1s infinite",
  "bubble:animation:spin 2s linear infinite",
  "bubble:animation:fade-in 0.5s",
  "bubble:animation:fade-out 0.5s",
  "bubble:background:radial-gradient(circle, red, yellow)",
  "bubble:background:linear-gradient(45deg, blue, purple)",
  "bubble:background:coral",
  "bubble:background:teal",
  "bubble:background:gold",
  "bubble:background:indigo",
  "bubble:boxShadow:0 10px 20px rgba(0,0,0,0.3)",
  "bubble:boxShadow:inset 0 0 15px white",
  "bubble:boxShadow:0 0 20px cyan",
  "bubble:border:3px solid white",
  "bubble:border:4px dashed orange",
  "bubble:borderRadius:20%",
  "bubble:borderRadius:10px",
  "bubble:transform:scale(1.1)",
  "bubble:transform:rotate(10deg)",
  "bubble:transform:translateX(10px)",
  "bubble:transform:skew(5deg)",
  "bubble:opacity:0.8",
  "bubble:opacity:0.5",
  "bubble:width:150px",
  "bubble:height:150px",
  "bubble:width:180px",
  "bubble:height:180px",
  "bubble:filter:drop-shadow(5px 5px 5px black)",
  "bubble:backdropFilter:blur(5px)",
  "bubble:transition:all 0.5s ease",
  "bubble:backgroundColor:darkgreen",
  "bubble:backgroundColor:maroon",
  "bubble:background:repeating-linear-gradient(45deg, pink, purple 20px)"
];

// Añadir 3 estilos con pseudo-clases (:hover, :active) para móvil/escritorio
const bubblePseudoStyles = [
  "bubble:hover:background:lime",
  "bubble:hover:transform:scale(1.2)",
  "bubble:active:background:red"
];

// Unir y asegurar exactamente 40
let bubbleStyles = [...bubbleNormalStyles, ...bubblePseudoStyles];
while (bubbleStyles.length < 40) bubbleStyles.push("bubble:background:gray");
bubbleStyles = bubbleStyles.slice(0, 40);

// ========== GENERAR 40 ESTILOS PARA TEXTO (SÓLO 3 CON PSEUDO) ==========
const textNormalStyles = [
  "text:animation:bounce 0.5s infinite",
  "text:animation:pulse 0.5s infinite",
  "text:animation:fade-in 1s",
  "text:color:cyan",
  "text:color:yellow",
  "text:color:lime",
  "text:color:orange",
  "text:color:hotpink",
  "text:fontSize:22px",
  "text:fontSize:26px",
  "text:fontWeight:bold",
  "text:fontWeight:lighter",
  "text:textShadow:2px 2px 4px black",
  "text:textShadow:0 0 5px red",
  "text:transform:scale(1.2)",
  "text:transform:rotate(2deg)",
  "text:transform:translateX(5px)",
  "text:letterSpacing:3px",
  "text:letterSpacing:5px",
  "text:backgroundColor:rgba(0,0,0,0.5)",
  "text:backgroundColor:rgba(255,255,0,0.3)",
  "text:padding:5px",
  "text:borderRadius:10px",
  "text:background:linear-gradient(90deg, red, blue)",
  "text:backgroundClip:text",
  "text:WebkitBackgroundClip:text",
  "text:color:transparent",
  "text:opacity:0.7",
  "text:fontFamily:monospace",
  "text:fontFamily:cursive",
  "text:textDecoration:underline",
  "text:textDecoration:overline",
  "text:fontStyle:italic",
  "text:wordSpacing:10px"
];

const textPseudoStyles = [
  "text:hover:color:gold",
  "text:hover:fontSize:28px",
  "text:active:color:red"
];

let textStyles = [...textNormalStyles, ...textPseudoStyles];
while (textStyles.length < 40) textStyles.push("text:color:white");
textStyles = textStyles.slice(0, 40);

// ========== FUNCIÓN TOGGLE ==========
function toggleStyle(styleRule) {
  let currentCode = cssInput.value;
  const lines = currentCode.split(";").map(l => l.trim()).filter(l => l !== "");
  const ruleIndex = lines.findIndex(line => line === styleRule);
  
  if (ruleIndex !== -1) {
    lines.splice(ruleIndex, 1);
    cssInput.value = lines.join(";") + (lines.length ? ";" : "");
  } else {
    if (currentCode && !currentCode.endsWith(";") && !currentCode.endsWith("\n")) {
      cssInput.value += ";" + styleRule;
    } else {
      cssInput.value += styleRule + ";";
    }
  }
  cssInput.dispatchEvent(new Event("input"));
}

// ========== RENDERIZAR PANEL ==========
function renderOptions(target) {
  optionsList.innerHTML = "";
  const stylesList = target === "bubble" ? bubbleStyles : textStyles;
  stylesList.forEach(styleRule => {
    const btn = document.createElement("button");
    btn.textContent = styleRule;
    btn.className = "bg-slate-700 hover:bg-slate-600 rounded px-2 py-1 text-left text-xs break-all";
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleStyle(styleRule);
    });
    optionsList.appendChild(btn);
  });
}

bubbleBtn.addEventListener("click", () => renderOptions("bubble"));
textBtn.addEventListener("click", () => renderOptions("text"));

// ========== RESET ==========
function resetAllStyles() {
  cssInput.value = "";
  document.querySelectorAll("style[data-keyframe], style[id='dynamic-pseudo-styles']").forEach(tag => tag.remove());
  bubble.style.cssText = "";
  bubbleText.style.cssText = "";
  cssInput.dispatchEvent(new Event("input"));
}
resetBtn.addEventListener("click", resetAllStyles);

// ========== PANEL TOGGLE ==========
togglePanel.addEventListener("click", () => {
  if (stylePanel.classList.contains("hidden")) {
    stylePanel.classList.remove("hidden");
    cssInput.classList.add("hidden");
    renderOptions("bubble");
  } else {
    stylePanel.classList.add("hidden");
    cssInput.classList.remove("hidden");
  }
});

// Inicializar
stylePanel.classList.add("hidden");
cssInput.classList.remove("hidden");
</script>
